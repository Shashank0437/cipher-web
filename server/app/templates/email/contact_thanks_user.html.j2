<!DOCTYPE html>
<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /></head>
  <body style="margin:0;padding:0;background-color:#f7f5fb;font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1b1528;">
    <span style="display:none!important;visibility:hidden;opacity:0;height:0;width:0">{{ preheader }}</span>
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="padding:24px;">
      <tr><td align="center">
        <table role="presentation" width="100%" style="max-width:560px;background:#ffffff;border-radius:12px;border:1px solid #e4dff0;box-shadow:0 1px 3px rgba(91,33,182,0.08);">
          <tr><td style="height:4px;background:linear-gradient(90deg,#7c3aed,#6366f1,#22d3ee);"></td></tr>
          <tr><td style="padding:28px 28px 24px;">
            <div style="font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:#6d28d9;font-weight:700;">CipherStrike</div>
            <h1 style="margin:12px 0 12px;font-size:20px;font-weight:700;color:#17131f;">Thanks for reaching out, {{ first_name }}</h1>
            <p style="margin:0;font-size:15px;line-height:1.6;color:#3f3a4f;">
              We’ve received your message and will contact you <strong style="color:#111827;">soon</strong> with next steps. If your request is urgent, reply to this email and reference the message you sent from our site.
            </p>
            <p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#64748b;">— The CipherStrike team</p>
          </td></tr>
        </table>
      </td></tr>
    </table>
  </body>
</html>
