<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vrika invitation</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f7f5fb;font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1b1528;">
    <span style="display:none!important;visibility:hidden;opacity:0;color:transparent;height:0;width:0">{{ preheader }}</span>
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f7f5fb;padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="max-width:560px;background:#ffffff;border-radius:18px;border:1px solid #e4dff0;box-shadow:0 1px 3px rgba(91,33,182,0.08);overflow:hidden;">
            <tr>
              <td style="height:6px;background:linear-gradient(90deg,#7c3aed,#6366f1,#22d3ee);"></td>
            </tr>
            <tr>
              <td style="padding:34px 32px 10px;">
                <div style="font-size:12px;letter-spacing:0.38em;text-transform:uppercase;color:#6d28d9;font-weight:800;">Vrika</div>
                <h1 style="margin:14px 0 6px;font-size:26px;line-height:1.2;font-weight:800;color:#17131f;letter-spacing:-0.02em;">You're invited</h1>
                <p style="margin:0 0 20px;font-size:16px;line-height:1.55;color:#3f3a4f;">
                  Hi <strong style="color:#111827;">{{ invitee_username }}</strong> — <strong style="color:#111827;">{{ inviter_display }}</strong> invited you to join
                  <strong style="color:#111827;">{{ organization_name }}</strong> on Vrika Offensive Security.
                </p>
                <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#faf5ff;border-radius:12px;border:1px solid #ede9fe;margin:20px 0;">
                  <tr>
                    <td style="padding:18px 20px;font-size:14px;line-height:1.65;color:#453c5c;">
                      Accept to create your password and enter the shared workspace — same security standards as approvals, packaged for teammates.
                    </td>
                  </tr>
                </table>
                <a href="{{ accept_url }}" style="display:inline-block;margin-top:10px;padding:15px 32px;border-radius:999px;background:linear-gradient(92deg,#7c3aed 0%,#6366f1 45%,#0ea5e9 100%);color:#ffffff;font-weight:800;font-size:15px;text-decoration:none;border:1px solid rgba(124,58,237,0.35);box-shadow:0 2px 8px rgba(124,58,237,0.22);">
                  Review invitation →
                </a>
                <p style="margin:30px 0 0;font-size:12px;line-height:1.65;color:#6b7280;">
                  If the button doesn't work, copy this link:<br />
                  <span style="word-break:break-all;color:#5b21b6;">{{ accept_url }}</span>
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding:0 32px 30px;">
                <p style="margin:16px 0 0;font-size:11px;line-height:1.55;color:#64748b;border-top:1px solid #ede9fe;padding-top:18px;">
                  This link expires for security. If you didn't expect an invite, you can safely ignore this message.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
