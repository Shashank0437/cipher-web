# NyxStrike agent (Flask). Local dev: 127.0.0.1. When the CipherStrike API runs in Docker and the
# agent runs on the host machine, use host.docker.internal and bind the agent with NYXSTRIKE_HOST=0.0.0.0.
# Example (API in Docker, agent on host): AGENT_MICROSERVICE_URL=http://host.docker.internal:8888
AGENT_MICROSERVICE_URL=http://127.0.0.1:8888
AGENT_API_TOKEN=
AGENT_TIMEOUT_SECONDS=10
# Max wait for each synchronous agent tool run (agent-chat batch slots, /workspace/tools/run). Nikto/nuclei often need >300s.
AGENT_TOOL_RUN_TIMEOUT_SECONDS=900
CIPHERSTRIKE_BRIDGE_SECRET=
AGENT_LLM_STREAM_TIMEOUT_SECONDS=600
# Max size of each tool JSON blob sent to the agent-chat LLM (default 56000). Long nmap stdout uses head+tail + progress-line stripping.
AGENT_CHAT_TOOL_RESULT_MAX_CHARS=56000
